{
  "name": "@biohazardfs/workspace-electron",
  "private": true,
  "version": "0.1.0",
  "description": "Biohazard Workspace Electron shell for BiohazardFS",
  "packageManager": "pnpm@10.33.0",
  "main": "dist/electron/main.js",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "pnpm run build:electron && pnpm run build:renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "start": "pnpm run build && electron dist/electron/main.js",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "lint": "eslint src --max-warnings=0",
    "format:check": "prettier --check .",
    "static": "pnpm run typecheck && pnpm run lint && pnpm run format:check",
    "test": "pnpm run static && vitest run",
    "test:unit": "vitest run",
    "build:rust:release": "cargo build --manifest-path ../../Cargo.toml --release --bins",
    "prepare:desktop-resources": "bash ../../scripts/release/prepare-desktop-resources.sh",
    "dist": "pnpm run build && pnpm run build:rust:release && pnpm run prepare:desktop-resources && bash ../../scripts/release/electron-builder.sh",
    "dist:dir": "pnpm run build && pnpm run build:rust:release && pnpm run prepare:desktop-resources && bash ../../scripts/release/electron-builder.sh --dir",
    "dist:linux": "pnpm run build && pnpm run build:rust:release && pnpm run prepare:desktop-resources -- --target-platform linux && bash ../../scripts/release/electron-builder.sh --linux AppImage deb",
    "dist:mac": "pnpm run build && pnpm run build:rust:release && pnpm run prepare:desktop-resources -- --target-platform mac && bash ../../scripts/release/electron-builder.sh --mac dmg zip",
    "dist:win": "pnpm run build && pnpm run build:rust:release && pnpm run prepare:desktop-resources -- --target-platform win && bash ../../scripts/release/electron-builder.sh --win nsis"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.0.0",
    "@radix-ui/react-dialog": "^1.0.0",
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "@radix-ui/react-progress": "^1.0.0",
    "@radix-ui/react-scroll-area": "^1.0.0",
    "@radix-ui/react-separator": "^1.0.0",
    "@radix-ui/react-slot": "^1.0.0",
    "@radix-ui/react-tooltip": "^1.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "com.biohazardvfx.biohazardfs.workspace",
    "productName": "Biohazard Workspace",
    "copyright": "Copyright \u00a9 Biohazard VFX",
    "artifactName": "BiohazardFS-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "release-metadata.json",
        "to": "release-metadata.json"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Biohazard-VFX",
        "repo": "BiohazardFS"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "artifactName": "BiohazardFS-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "executableName": "biohazard-workspace"
  },
  "author": "Biohazard VFX"
}
